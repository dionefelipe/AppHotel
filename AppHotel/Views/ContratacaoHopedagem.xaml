<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AppHotel.Views.ContratacaoHopedagem"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="{StaticResource Gray600}">

    <VerticalStackLayout Padding="8">
        <Label  Text="Calculo da Diaria" 
                FontFamily="Mono-Italic"
                FontSize="40"
                TextColor="{StaticResource Gray300}"
                HorizontalTextAlignment="Center" />


        <Frame Padding="10" BackgroundColor="{StaticResource Tertiary}">

            <VerticalStackLayout>
                <Grid RowDefinitions="auto, auto"
                          ColumnDefinitions="*, *, 2*">

                    <Label Grid.Row="0" Grid.Column="0"
                               Text="Adultos:"/>

                    <Label
                            Grid.Row="0" Grid.Column="1"
                            TextColor="{StaticResource Gray300}"
                            Text="{Binding Value}"
                            BindingContext="{x:Reference stp_adultos}" />

                    <Stepper Grid.Row="0" Grid.Column="2"
                            x:Name="stp_adultos"
                            Minimum="0"
                            Maximum="10"
                            Increment="1"/>

                    <Label Grid.Row="1" Grid.Column="0"
                               Text="Criança:"/>

                    <Label
                            Grid.Row="1" Grid.Column="1"
                            TextColor="{StaticResource Gray300}"
                            Text="{Binding Value}"
                            BindingContext="{x:Reference stp_criancas}" />

                    <Stepper Grid.Row="1" Grid.Column="2"
                            x:Name="stp_criancas"
                            Minimum="0"
                            Maximum="10"
                            Increment="1"/>

                </Grid>

                <Label Text="Escolha sua Suite" />

                <Picker x:Name="pck_quarto"
                        Title="Selecione Acomadação: "
                        ItemDisplayBinding="{Binding Descricao}"/>

                <Frame
                    Padding="10"
                    Margin="10"
                    BackgroundColor="{StaticResource Tertiary}">
                    <VerticalStackLayout>
                        <Label Text="Período da Entadia: "/>

                        <HorizontalStackLayout>
                            <Label Text="Check-in:"/>
                            <DatePicker x:Name="dtpck_checkin"
                                        DateSelected="dtpck_checkin_DateSelected"
                                        Format="dd/MM/yyyy" />
                        </HorizontalStackLayout>

                        <HorizontalStackLayout>
                            <Label Text="Check-out:"/>
                            <DatePicker x:Name="dtpck_checkout"
                                        Format="dd/MM/yyyy" />
                        </HorizontalStackLayout>

                    </VerticalStackLayout>
                </Frame>

                <Button Text="Calcular" 
                        HorizontalOptions="Center"
                        Clicked= "Button_Clicked"/>
                
                <Button Text="Inicio" 
                        HorizontalOptions="Center"
                        Clicked="Button_Clicked_1"/>

            </VerticalStackLayout>
        </Frame>
    </VerticalStackLayout>
</ContentPage>